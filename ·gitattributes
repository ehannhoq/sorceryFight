# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf
 
# Explicitly declare text files
*.js         text eol=lf
*.jsx        text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.json       text eol=lf
*.css        text eol=lf
*.scss       text eol=lf
