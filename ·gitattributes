*.yaml       text eol=lf
*.yml        text eol=lf
*.xml        text eol=lf
*.svg        text eol=lf
*.txt        text eol=lf
*.sh         text eol=lf
*.bash       text eol=lf
*.py         text eol=lf
*.rb         text eol=lf
*.go         text eol=lf
*.rs         text eol=lf
